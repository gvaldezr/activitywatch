# ActivityWatch Server Configuration
# This file demonstrates how to configure aw-server for remote connections and PostgreSQL

# =============================================================================
# Server Binding Configuration (aw-server-rust & aw-server)
# =============================================================================

# Server listening address
# Default: 127.0.0.1 (localhost only)
# Set to 0.0.0.0 to listen on all interfaces (REQUIRES FIREWALL + REVERSE PROXY)
# See docs/REMOTE_CONNECTIONS.md for security guidance
AW_SERVER_HOST=127.0.0.1

# Server listening port
# Default: 5600 (or 5666 in testing mode)
AW_SERVER_PORT=5600

# =============================================================================
# Client Configuration (aw-client)
# =============================================================================

# When connecting to a remote aw-server from aw-client on different machines:
# Set these environment variables:

# AW_SERVER_HOST=remote.server.com      # Remote server address
# AW_SERVER_PORT=5600                   # Remote server port
# AW_SERVER_API_KEY=your_api_key        # API key from server config (for authentication)

# =============================================================================
# Storage Backend Configuration
# =============================================================================

# Storage method: "peewee" (SQLite), "postgres" (PostgreSQL), or "memory" (testing)
# Default: peewee (SQLite)
AW_STORAGE=peewee

# =============================================================================
# PostgreSQL Connection (if AW_STORAGE=postgres)
# =============================================================================

# Option 1: Use DATABASE_URL environment variable (recommended for cloud deployments)
# Format: postgresql://[user[:password]@][netloc][:port][/dbname][?param1=value1&...]
# Example: postgresql://activitywatch:my_secure_password@db.example.com:5432/activitywatch
DATABASE_URL=postgresql://postgres:password@localhost:5432/activitywatch

# Option 2: Or use individual connection parameters
# Database host (default: localhost)
DB_HOST=localhost

# Database port (default: 5432)
DB_PORT=5432

# Database name (default: activitywatch)
DB_NAME=activitywatch

# Database user (default: postgres)
DB_USER=postgres

# Database password (no default - required if PostgreSQL has authentication)
DB_PASSWORD=your_secure_password

# =============================================================================
# Logging Configuration
# =============================================================================

# Rust logging level: trace, debug, info, warn, error
# Default: info
RUST_LOG=info

# Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
AW_LOG_LEVEL=INFO

# =============================================================================
# Optional: CORS Configuration
# =============================================================================

# CORS origins (comma-separated list of allowed origins for cross-origin requests)
# Example: "http://localhost:3000,https://example.com"
AW_CORS_ORIGINS=

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
RUST_LOG=info

# Enable detailed logging for aw-server (Python)
AW_LOG_LEVEL=INFO

# =============================================================================
# Migration Configuration (when migrating from SQLite to PostgreSQL)
# =============================================================================

# Path to source SQLite database file (used by migration script)
# Example: ~/.local/share/aw-server/peewee-sqlite.v2.db
SQLITE_DB_PATH=

# Target PostgreSQL database URL (where to migrate data to)
# Can be same as DATABASE_URL above
MIGRATE_TARGET_URL=postgresql://postgres:password@localhost:5432/activitywatch

# Enable verbose output during migration
MIGRATE_VERBOSE=true

# =============================================================================
# Connection Pool Configuration (PostgreSQL)
# =============================================================================

# Minimum number of connections in the pool (default: 1)
DB_POOL_MIN=1

# Maximum number of connections in the pool (default: 10)
DB_POOL_MAX=10

# Connection timeout in seconds (default: 10)
DB_TIMEOUT=10

# Idle timeout in seconds before closing unused connections (default: 300)
DB_IDLE_TIMEOUT=300

# =============================================================================
# Development / Testing
# =============================================================================

# Run in testing mode (uses separate test database)
AW_TESTING=false

# Skip SSL verification for database connection (not recommended for production)
DB_SSLMODE=require  # Options: disable, allow, prefer, require, verify-ca, verify-full
